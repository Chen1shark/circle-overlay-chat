server:
  # 后端监听端口：前端 VITE_CIRCLE_SERVER_WS_URL 的端口要和这里一致。
  port: 8080

chat:
  # 房间口令：客户端进入房间时输入的口令必须和这里一致。
  access-key: "replace-with-your-access-key"
  max-connections: 300
  max-rooms: 50
  max-users-per-room: 10
  history-limit: 200
  max-message-length: 500
  # 单张图片压缩后允许发送的最大字节数：默认约 650KB。
  max-image-bytes: 665600
  # WebSocket 单条消息缓冲区：图片会以 dataUrl 放在 JSON 里，需大于 max-image-bytes 的 base64 体积。
  websocket-message-buffer-bytes: 950000
  # WebSocket 空闲超时：客户端每 20 秒发送 ping，断线后默认最多约 90 秒清理僵尸连接。
  websocket-idle-timeout-ms: 90000

  ai:
    # 是否启用房间 AI 虚拟成员；未配置模型密钥前保持 false。
    enabled: false
    # AI 在成员列表和聊天消息中的显示名称；真实名称请只写入本地 application.yml。
    name: ""
    # AI 角色提示词；真实提示词请只写入本地 application.yml。
    prompt: ""
    # OpenAI 兼容接口地址，可填写 https://example.com/v1 或完整 /chat/completions 地址。
    base-url: ""
    # OpenAI 兼容接口密钥；不要提交真实密钥。
    api-key: ""
    # 模型名称。
    model: ""
    # 回复随机性，0.7 适合聊天角色。
    temperature: 0.7
    # 单次回复最大输出 token 数。
    max-output-tokens: 800
    # AI 请求超时时间，单位毫秒。
    timeout-ms: 30000
    # 兼容支持 thinking 字段的模型：true 时请求体加入 thinking.type=disabled。
    thinking-disabled: true
